data/interim/
data/glyphs/

# ---- Imagens geradas ----
# Versiona só as amostras que o view.html referencia; ignora o resto que se acumula.
output/*
!output/generated.png
!output/generated_seed11.png
!output/generated_seed23.png

# ---- SO / editores / ferramentas ----
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
.claude/settings.local.json

